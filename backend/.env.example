# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# MongoDB Atlas (recommended for cloud)
# Format: mongodb+srv://<username>:<password>@<cluster-host>/<dbName>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/almts?retryWrites=true&w=majority

# Local MongoDB (if you want to use Compass/local instead)
# MONGODB_URI=mongodb://localhost:27017/almts

# DNS (optional)
# If you see errors like: "querySrv ECONNREFUSED _mongodb._tcp....", your network/DNS may block Node's DNS queries.
# Setting public DNS servers here lets Node resolve Atlas SRV/A records reliably.
DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=ALMTS <noreply@almts.com>

# Frontend URL
# No trailing slash. Example: https://student-momentum.vercel.app
FRONTEND_URL=http://localhost:5173
# Optional: allow multiple origins (comma-separated)
# FRONTEND_URLS=https://student-momentum.vercel.app,https://student-momentum-git-main-<user>.vercel.app

# AI Tutor (Hugging Face Inference API - free tier)
# Create a token at https://huggingface.co/settings/tokens (Read access)
# HF_API_TOKEN=hf_xxx
# Optional model override (text2text model recommended)
# HF_TUTOR_MODEL=google/flan-t5-small
# AI_TUTOR_TIMEOUT_MS=15000

# News Moderation (Free NLP - keyword + sentiment)
# Set to "false" to disable moderation entirely.
# NEWS_MODERATION_ENABLED=true
# Comma-separated additional bad words / phrases (optional)
# NEWS_BAD_WORDS=
# NEWS_BLOCK_PHRASES=
# More negative => stricter. Range -1..0.
# NEWS_SENTIMENT_BLOCK_THRESHOLD=-0.6
# NEWS_TOXIC_NEGATIVE_WORD_MIN=3

# Assignments (Free Tools)
# Plagiarism check threshold (TF-IDF cosine similarity)
# PLAGIARISM_THRESHOLD=0.78
# Enable code autograding for CODE_JS assignments (runs untrusted code with a timeout; use with caution)
# CODE_AUTOGRADE_ENABLED=false
# Extra safety switch: must be true to actually run student code
# CODE_AUTOGRADE_ACK_RISK=false
# Optional: allow any `*.vercel.app` origin (useful for preview deployments)
# ALLOW_VERCEL_APP_ORIGINS=true

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
